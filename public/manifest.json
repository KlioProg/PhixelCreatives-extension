{
  "manifest_version": 3,
  "name": "Phixel",
  "version": "1.0.0",
  "description": "A powerful color extraction and palette companion designed for creatives.",
  "action": {
    "default_popup": "index.html"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}